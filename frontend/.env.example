# Default: frontend calls /api, and Vite proxies it to the local Python API.
VITE_API_BASE_URL=/api
VITE_PROXY_TARGET=http://127.0.0.1:55173

# Option A: keep the frontend URL local, but proxy /api to a remote backend.
# VITE_PROXY_TARGET=http://10.181.9.70:5173

# Option B: let the browser call a remote backend directly.
# VITE_API_BASE_URL=http://10.181.9.70:5173/api
